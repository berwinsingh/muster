{
  "name": "muster",
  "displayName": "Muster",
  "description": "One-click dev server group orchestration with MCP agent integration",
  "version": "0.1.10",
  "publisher": "muster",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/berwinsingh/muster.git"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "dev server",
    "orchestration",
    "process manager",
    "terminal",
    "monorepo",
    "fullstack",
    "mcp",
    "agent"
  ],
  "galleryBanner": {
    "color": "#0b0d10",
    "theme": "dark"
  },
  "icon": "media/icon.png",
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:.vscode/muster.json",
    "onView:muster.groups",
    "onView:muster.issues",
    "onCommand:muster.createGroup",
    "onCommand:muster.openVisualEditor",
    "onCommand:muster.importExample",
    "onCommand:muster.openConfig"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "muster.runGroup",
        "title": "Run Group",
        "category": "Muster"
      },
      {
        "command": "muster.stopGroup",
        "title": "Stop Group",
        "category": "Muster"
      },
      {
        "command": "muster.restartGroup",
        "title": "Restart Group",
        "category": "Muster"
      },
      {
        "command": "muster.runService",
        "title": "Run Service",
        "category": "Muster"
      },
      {
        "command": "muster.openConfig",
        "title": "Open Config",
        "category": "Muster"
      },
      {
        "command": "muster.refresh",
        "title": "Refresh",
        "category": "Muster",
        "icon": "$(refresh)"
      },
      {
        "command": "muster.runGroupFromTree",
        "title": "Run Group",
        "category": "Muster",
        "icon": "$(play)"
      },
      {
        "command": "muster.stopGroupFromTree",
        "title": "Stop Group",
        "category": "Muster",
        "icon": "$(debug-stop)"
      },
      {
        "command": "muster.restartGroupFromTree",
        "title": "Restart Group",
        "category": "Muster",
        "icon": "$(debug-restart)"
      },
      {
        "command": "muster.runServiceFromTree",
        "title": "Run Service",
        "category": "Muster",
        "icon": "$(play)"
      },
      {
        "command": "muster.openVisualEditor",
        "title": "Configure",
        "category": "Muster",
        "icon": "$(edit)"
      },
      {
        "command": "muster.createGroup",
        "title": "Create Group",
        "category": "Muster",
        "icon": "$(add)"
      },
      {
        "command": "muster.importExample",
        "title": "Import Example",
        "category": "Muster",
        "icon": "$(cloud-download)"
      },
      {
        "command": "muster.editGroup",
        "title": "Edit Group",
        "category": "Muster",
        "icon": "$(edit)"
      }
    ],
    "viewsWelcome": [
      {
        "view": "muster.groups",
        "contents": "No server groups configured yet.\nUse the **+** (Create Group) and pencil (Configure) icons in the title bar.\n[Create Group](command:muster.createGroup)\n[Import Example](command:muster.importExample)\n[Open Visual Editor](command:muster.openVisualEditor)",
        "when": "!muster.hasConfigFile && !muster.hasGroups"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "muster",
          "title": "Muster",
          "icon": "media/muster.svg"
        }
      ]
    },
    "views": {
      "muster": [
        {
          "id": "muster.groups",
          "name": "Server Groups"
        },
        {
          "type": "webview",
          "id": "muster.issues",
          "name": "Events"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "muster.runGroup",
          "when": "true"
        },
        {
          "command": "muster.stopGroup",
          "when": "true"
        },
        {
          "command": "muster.restartGroup",
          "when": "true"
        },
        {
          "command": "muster.runService",
          "when": "true"
        },
        {
          "command": "muster.openConfig",
          "when": "true"
        },
        {
          "command": "muster.refresh",
          "when": "true"
        },
        {
          "command": "muster.openVisualEditor",
          "when": "true"
        },
        {
          "command": "muster.createGroup",
          "when": "true"
        },
        {
          "command": "muster.importExample",
          "when": "true"
        },
        {
          "command": "muster.runGroupFromTree",
          "when": "false"
        },
        {
          "command": "muster.stopGroupFromTree",
          "when": "false"
        },
        {
          "command": "muster.restartGroupFromTree",
          "when": "false"
        },
        {
          "command": "muster.runServiceFromTree",
          "when": "false"
        },
        {
          "command": "muster.editGroup",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "muster.createGroup",
          "when": "view == muster.groups",
          "group": "navigation@1"
        },
        {
          "command": "muster.openVisualEditor",
          "when": "view == muster.groups",
          "group": "navigation@2"
        },
        {
          "command": "muster.refresh",
          "when": "view == muster.groups",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "muster.openVisualEditor",
          "when": "view == muster.groups && viewItem == error",
          "group": "inline@1"
        },
        {
          "command": "muster.runGroupFromTree",
          "when": "view == muster.groups && viewItem == group",
          "group": "inline@1"
        },
        {
          "command": "muster.stopGroupFromTree",
          "when": "view == muster.groups && viewItem == group",
          "group": "inline@2"
        },
        {
          "command": "muster.restartGroupFromTree",
          "when": "view == muster.groups && viewItem == group",
          "group": "inline@3"
        },
        {
          "command": "muster.runServiceFromTree",
          "when": "view == muster.groups && viewItem == service",
          "group": "inline@1"
        },
        {
          "command": "muster.editGroup",
          "when": "view == muster.groups && viewItem == group",
          "group": "1_edit@1"
        }
      ]
    },
    "configuration": {
      "title": "Muster",
      "properties": {
        "muster.defaultGroup": {
          "type": "string",
          "default": "",
          "description": "Default server group id for status bar toggle"
        },
        "muster.keepExistingTerminals": {
          "type": "boolean",
          "default": true,
          "description": "Do not close existing terminals when starting a group"
        },
        "muster.orchestratorTerminal": {
          "type": "boolean",
          "default": true,
          "description": "Show the Muster orchestrator terminal that narrates group startup: launches, ready checks, dependency order, and final status"
        },
        "muster.allowExternalCwd": {
          "type": "boolean",
          "default": false,
          "description": "Allow service cwd outside the workspace folder"
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "compile:test": "node esbuild.mjs --test",
    "watch": "node esbuild.mjs --watch",
    "prepare-icons": "node scripts/prepare-icons.mjs",
    "package": "npm run prepare-icons && npm run compile && vsce package",
    "test": "npm run compile:test && node --require ./src/test/vscode-shim.cjs --test dist-test/**/*.test.js",
    "test:integration": "npm run compile && node scripts/run-integration-tests.cjs",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.96.0",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.25.0",
    "sharp": "^0.35.3",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.0"
  }
}
